# This file serves as a template for setting up your local development environment

# Google OAuth credentials (required by `deno task dev` when initializing the local Supabase stack)
# You need to create your own Google OAuth credentials for local development
AUTH_GOOGLE_CLIENT_ID=your-google-client-id
AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# The following values are used by the local Supabase self-hosted instance
# These values are standard defaults for local development and can be kept as-is
# They are the same for every local Supabase instance and don't need to be hidden

EDGE_URL=http://kong:8000/functions/v1/
# Local secret key seeded into the vault for the cron jobs.
# MUST match [auth] secret_key in supabase/config.toml, or cron POSTs 401.
SECRET_KEY=sb_secret_a_secret
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
